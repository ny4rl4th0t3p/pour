## chains.yml — pour faucet configuration
## Copy to chains.yml and edit. Set POUR_MNEMONIC in your environment.

abuse:
  # All mechanisms default to false — enable what you need.
  pow:
    enabled: true
    difficulty: medium          # easy | medium | hard | <positive integer>

  api_keys:
    enabled: true

  signature_challenge:
    enabled: false
    require_predicate: none     # none | has_balance
    # predicate_chain_id: ""    # chain to query for the predicate; defaults to the chain being dripped
    # predicate_min_amount: ""  # required when require_predicate is has_balance (e.g. "1000000uatom")

  ip_rate_limit:
    requests_per_window: 10     # number of requests allowed per window
    window: 1h                  # duration window: 1h, 30m, 5m, etc. (default: 1h)

chains:
  - chain_id: osmosis-1
    enabled: true
    bech32_prefix: osmo
    slip44: 118
    endpoints:
      grpc:
        - grpc.osmosis.zone:443
    fee_tokens:
      - denom: uosmo
        average_gas_price: "0.025"
        low_gas_price: "0.01"
    drip:
      anonymous: 1000000uosmo                 # REQUIRED
      signed: 5000000uosmo                    # optional: higher drip for signed-wallet requests
      max_per_address_per_day: 50000000uosmo  # REQUIRED

    ## Concurrency — optional; production-grade example shown below
    distributors: 3               # signing accounts (indices 1..N); default 1
    batch_window: 5s              # flush interval; "0" = synchronous/no-batch mode; default 5s
    max_recipients_per_batch: 25  # outputs per MsgMultiSend; default 25
    # max_queue_depth: 500          # per-distributor queue cap; default 500
    # refill_threshold: ""          # min distributor balance; empty = drip.anonymous × 10

    ## IBC — optional; controls MsgTransfer timeout for outbound IBC transfers
    # ibc:
    #   timeout: 10m     # MsgTransfer timeout; default 10m; increase for slow relayers

  ## IBC drips — offer ATOM vouchers on osmosis-1 sourced from cosmoshub-4 via MsgTransfer.
  ## Users request them with {"chain_id":"osmosis-1","address":"...","denom":"uatom"}.
  ## The source chain (cosmoshub-4) must also be present in this config.
  ## cosmoshub-4 can be configured with its own drip block (also serves as an ATOM faucet)
  ## or as a source-only chain (no drip block; only broadcasts MsgTransfer for IBC drips).
  ## Both native uosmo drips and IBC uatom voucher drips can be used simultaneously.
  # ibc:
  #   timeout: 10m
  #   drips:
  #     - source_chain_id: cosmoshub-4   # tokens are sent from cosmoshub-4 via MsgTransfer
  #       anonymous: 1000000uatom
  #       max_per_address_per_day: 10000000uatom

  ## IBC-only destination chain — no gRPC endpoints or native wallet needed here.
  ## Users receive uatom vouchers on this chain via MsgTransfer from cosmoshub-4.
  # - chain_id: myibc-1
  #   enabled: true
  #   ibc:
  #     timeout: 10m
  #     drips:
  #       - source_chain_id: cosmoshub-4
  #         anonymous: 1000000uatom
  #         max_per_address_per_day: 10000000uatom

  ## IBC source-only chain — has a funded wallet and endpoints to broadcast MsgTransfer,
  ## but does not serve native drips. Useful when you only want to offer IBC vouchers
  ## to another chain without exposing a public ATOM faucet on cosmoshub-4 itself.
  # - chain_id: cosmoshub-4
  #   enabled: true
  #   endpoints:
  #     grpc:
  #       - grpc.cosmos.network:443
  #   fee_tokens:
  #     - denom: uatom
  #       average_gas_price: "0.025"
  #   # No drip block — native drips disabled; only referenced as source_chain_id above.

  ## Standalone / local devnet chain — use with `pour serve --auto` or manually.
  ## standalone: true skips the chain registry; all fields must be set explicitly.
  ## Tip: `pour serve --auto --home ~/.simapp` auto-generates this config from genesis.
  # - chain_id: mychain-1
  #   standalone: true
  #   enabled: true
  #   bech32_prefix: cosmos
  #   slip44: 118
  #   endpoints:
  #     grpc:
  #       - localhost:9090
  #     # rest:               # use instead of (or alongside) grpc for LCD-only nodes
  #     #   - http://localhost:1317
  #   fee_tokens:
  #     - denom: stake
  #       average_gas_price: "0.025"
  #   drip:
  #     anonymous: 1000000stake
  #     max_per_address_per_day: 10000000stake
  #   batch_window: "0s"   # synchronous mode — recommended for single-node devnets