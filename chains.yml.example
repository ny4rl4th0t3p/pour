## chains.yml — pour faucet configuration
## Copy to chains.yml and edit. Set POUR_MNEMONIC in your environment.

abuse:
  ip_rate_limit:
    requests_per_window: 10   # number of requests allowed per window
    window: 1h          # duration window: 1h, 30m, 5m, etc. (default: 1h)

chains:
  - chain_id: osmosis-1
    enabled: true
    bech32_prefix: osmo
    slip44: 118
    endpoints:
      grpc:
        - grpc.osmosis.zone:443
    fee_tokens:
      - denom: uosmo
        average_gas_price: "0.025"
        low_gas_price: "0.01"
    drip:
      anonymous: 1000000uosmo                 # REQUIRED
      max_per_address_per_day: 50000000uosmo  # REQUIRED

    ## Concurrency — all optional, defaults shown
    # distributors: 1               # signing accounts (indices 1..N); 0 = default (1)
    # batch_window: 5s              # flush interval; "0" = synchronous/no-batch mode
    # max_recipients_per_batch: 25  # outputs per MsgMultiSend; 0 = default (25)
    # max_queue_depth: 500          # per-distributor queue cap; 0 = default (500)
    # refill_threshold: ""          # min distributor balance; empty = drip.anonymous × distributors × 10